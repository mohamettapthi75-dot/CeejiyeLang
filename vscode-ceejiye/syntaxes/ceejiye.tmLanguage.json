{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "CeejiyeLang",
	"patterns": [
		{
			"include": "#keywords"
		},
		{
			"include": "#strings"
		},
		{
			"include": "#comments"
		},
		{
			"include": "#numbers"
		}
	],
	"repository": {
		"keywords": {
			"patterns": [{
				"name": "keyword.control.cee",
				"match": "\\b(hadii|haddii|kale|hadii_kale|inta|markale|wareeg|loo|shaqo|soo_celi|celi|fasalka|keen|ka_soo_qaado|jooji|siiwad|sii_wad|isku_day|qalad|khalad|qab|ugu_dambeyn|ugu_dambayn|dhaaf|la_dhaaf|mar|hubi|dhal|kici|kor_u_qaad|tirtir|guud|iyo|ama|maaha|ma_aha|ku_jira|kuma_jira|waa|ee|lambar|in)\\b"
			},
			{
				"name": "constant.language.cee",
				"match": "\\b(run|been|eber|waxba|maran)\\b"
			},
			{
				"name": "variable.language.special.cee",
				"match": "\\b(nafta)\\b"
			},
			{
				"name": "support.function.cee",
				"match": "\\b(daabac|geli|gel|nooc|nooca|dherer|tiro|jajab|sabbeeye|liis|qoraal|qaamuus|boole|kala_guur|xidid|xidh|xaddid|fur|xir|caawi|xisaab)\\b"
			}]
		},
		"strings": {
			"patterns": [{
				"name": "string.quoted.double.cee",
				"begin": "\"",
				"end": "\"",
				"patterns": [
					{
						"name": "constant.character.escape.cee",
						"match": "\\\\."
					}
				]
			},
			{
				"name": "string.quoted.single.cee",
				"begin": "'",
				"end": "'",
				"patterns": [
					{
						"name": "constant.character.escape.cee",
						"match": "\\\\."
					}
				]
			}]
		},
		"comments": {
			"patterns": [{
				"name": "comment.line.number-sign.cee",
				"match": "#.*$"
			}]
		},
		"numbers": {
			"patterns": [{
				"name": "constant.numeric.cee",
				"match": "\\b[0-9]+(\\.[0-9]+)?\\b"
			}]
		}
	},
	"scopeName": "source.cee"
}
